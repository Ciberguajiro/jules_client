{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "jules-client",
  "version": "0.2.0",
  "identifier": "com.ciberguajiro.jules-client",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1422",
    "beforeBuildCommand": "bun run build:prod",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "jules-client",
        "width": 800,
        "height": 600,
        "devtools": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://*; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://jules.googleapis.com; font-src 'self' data:;"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "A modern desktop client for the Jules API",
    "longDescription": "Jules Client is a modern desktop application that provides a clean and efficient interface for interacting with the Jules API, making it easy to manage AI coding sessions.",
    "externalBin": [],
    "copyright": "",
    "license": "MIT",
    "licenseFile": "../LICENSE",
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdERUQxNTMxOTJDNzdBQjgKUldTNGVzZVNNUlh0ZmZ6ZkYxTElXakVaUWcxTWRDTkFuRS9qb3NpaTlJUU1jek5TU2F3clQ3bEcK",
      "endpoints": [
        "https://github.com/ciberguajiro/jules-client/releases/latest/download/latest.json"
      ]
    }
  }
}
