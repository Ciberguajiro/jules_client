{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "jules-client",
  "version": "0.1.2",
  "identifier": "com.ciberguajiro.jules-client",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1422",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "jules-client",
        "width": 800,
        "height": 600,
        "devtools": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://*; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://jules.googleapis.com;"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdERUQxNTMxOTJDNzdBQjgKUldTNGVzZVNNUlh0ZmZ6ZkYxTElXakVaUWcxTWRDTkFuRS9qb3NpaTlJUU1jek5TU2F3clQ3bEcK",
      "endpoints": [
        "https://github.com/ciberguajiro/jules-client/releases/latest/download/latest.json"
      ]
    }
  }
}
